		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.2",
		"@vitest/browser": "^4.1.10",
		"playwright": "^1.61.1",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"vite": "^8.1.4",
		"vitest": "^4.1.10",
